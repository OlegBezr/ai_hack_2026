# Supabase connection. The anon key is safe to expose to the browser; it only
# grants RLS-scoped access. These PUBLIC_ vars are baked in at build time.
#
# Local dev (`pnpm dev`) — point at the local Supabase stack (`supabase status`):
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Production (`pnpm build`) — put the hosted project's values in .env.production,
# and set the same two vars in your host's dashboard (Vercel / Cloudflare Pages):
#   PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
#   PUBLIC_SUPABASE_ANON_KEY=<hosted-anon-key>
