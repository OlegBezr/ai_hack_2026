{
  "lock": false,
  "imports": {
    "@supabase/supabase-js": "jsr:@supabase/supabase-js@^2.49.0",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/http": "jsr:@std/http@^1"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
